---
import { site } from '@config/site';

interface Props {
  active?: string;
}

const { active = 'Matches' } = Astro.props;
---

<nav
  class="fixed top-0 w-full z-50 border-b border-outline-variant/15 bg-background/70 backdrop-blur-xl transition-all duration-300"
>
  <div class="flex justify-between items-center px-6 md:px-8 py-4 max-w-7xl mx-auto">
    <a href="/" class="flex items-center gap-2">
      <img src="/images/gdg_logo.png" alt="GDG Indore" class="h-8" />
    </a>
    <div class="hidden md:flex items-center gap-8 font-headline font-medium text-sm tracking-tight" data-nav-links>
      {
        site.nav.map((item) => {
          const isActive = item.label === active;
          return (
            <a
              href={item.href}
              data-nav-label={item.label}
              class={
                isActive
                  ? 'text-primary border-b-2 border-primary-fixed pb-1'
                  : 'text-on-surface/60 hover:text-primary transition-colors'
              }
            >
              {item.label}
            </a>
          );
        })
      }
    </div>
    <div class="flex items-center gap-4">
      <!-- Register Button -->
      {site.registerCta && (
        <a
          href={site.registerCta.href}
          class="hidden md:inline-block bg-surface border border-outline text-on-surface font-headline font-bold px-6 py-2 rounded-full transition-all hover:bg-surface-variant active:scale-95 text-sm"
        >
          {site.registerCta.label}
        </a>
      )}
      <!-- RSVP (formerly Leaderboard) Button -->
      <a
        href={site.cta.href}
        class="bg-primary-container text-on-primary-container font-headline font-bold px-6 py-2 rounded-full neon-glow transition-all active:scale-95 text-sm"
      >
        {site.cta.label}
      </a>
    </div>
  </div>
</nav>

<script>
  const ACTIVE = 'text-primary border-b-2 border-primary-fixed pb-1';
  const INACTIVE = 'text-on-surface/60 hover:text-primary transition-colors';

  // Only run scroll-spy on the landing page (where sections exist)
  const sections = document.querySelectorAll<HTMLElement>('#playbook, #partners');
  if (sections.length > 0) {
    const links = document.querySelectorAll<HTMLAnchorElement>('[data-nav-links] a[data-nav-label]');

    const setActive = (label: string) => {
      links.forEach((a) => {
        a.className = a.getAttribute('data-nav-label') === label ? ACTIVE : INACTIVE;
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            const label = id === 'playbook' ? 'Playbook' : id === 'partners' ? 'Partners' : null;
            if (label) setActive(label);
          }
        }
        // If none of the anchor sections are visible, default to Matches
        const anyVisible = [...sections].some((s) => {
          const r = s.getBoundingClientRect();
          return r.top < window.innerHeight && r.bottom > 0;
        });
        if (!anyVisible) setActive('Matches');
      },
      { threshold: 0.3 }
    );

    sections.forEach((s) => observer.observe(s));
  }
</script>
