---
import { site } from '@config/site';

interface Props {
  active?: string;
}

const { active = 'Matches' } = Astro.props;
---

<nav
  class="fixed top-0 w-full z-50 border-b border-outline-variant/15 bg-background/70 backdrop-blur-xl transition-all duration-300"
>
  <div class="flex justify-between items-center px-6 md:px-8 py-4 max-w-7xl mx-auto">
    <a href="/" class="text-xl font-bold tracking-tighter text-on-surface flex items-center gap-2">
      <span class="material-symbols-outlined text-primary">code</span>
      <span class="font-headline font-extrabold uppercase tracking-tight">{site.brand}</span>
    </a>
    <div class="hidden md:flex items-center gap-8 font-headline font-medium text-sm tracking-tight">
      {
        site.nav.map((item) => {
          const isActive = item.label === active;
          return (
            <a
              href={item.href}
              class={
                isActive
                  ? 'text-primary border-b-2 border-primary-fixed pb-1'
                  : 'text-on-surface/60 hover:text-primary transition-colors'
              }
            >
              {item.label}
            </a>
          );
        })
      }
    </div>
    <div class="flex items-center gap-4">
      <a
        href={site.cta.href}
        class="bg-primary-container text-on-primary-container font-headline font-bold px-6 py-2 rounded-full neon-glow transition-all active:scale-95 text-sm"
      >
        {site.cta.label}
      </a>
    </div>
  </div>
</nav>
