---
import { hero } from '@config/landing/hero';
import { site } from '@config/site';

const { badge, title, tagline, taglineTwo, primaryCta, secondaryCta, image } = hero;
---

<section class="relative px-6 md:px-8 pt-28 md:pt-32 pb-20 max-w-7xl mx-auto overflow-hidden">
  <div class="relative z-10 flex flex-col items-center text-center lg:items-start lg:text-left gap-8">
    <div
      class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-surface-container-low border border-outline-variant/15 text-xs font-mono tracking-widest text-primary uppercase"
    >
      <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
      {badge}
    </div>
    <h1 class="text-5xl md:text-7xl lg:text-8xl font-headline font-extrabold tracking-tighter leading-[0.9] max-w-4xl">
      <span class="gemini-gradient">{title}</span>
    </h1>
    <p class="text-lg md:text-2xl text-on-surface-variant font-headline font-medium max-w-2xl leading-relaxed">
      {tagline} <br />{taglineTwo}
    </p>
    <div class="flex flex-wrap gap-4 mt-4 justify-center lg:justify-start">
      {site.features?.watchParty && (
        <a
          href={primaryCta.href}
          class="bg-primary text-on-primary px-8 py-4 rounded-full font-headline font-bold text-lg shadow-[0px_20px_40px_rgba(15,107,0,0.2)] hover:scale-105 transition-transform"
        >
          {primaryCta.label}
        </a>
      )}
      {site.features?.leaderboard && (
        <a
          href={secondaryCta.href}
          class="glass-card px-8 py-4 rounded-full font-headline font-bold text-lg hover:bg-surface-container-low transition-colors"
        >
          {secondaryCta.label}
        </a>
      )}
    </div>
  </div>
  <div class="absolute -right-20 top-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-3xl -z-10"></div>
  <div class="absolute right-8 bottom-8 lg:block hidden">
    <div
      class="w-96 h-96 glass-card rounded-full flex items-center justify-center border-2 border-primary/20 rotate-12 kinetic-shimmer"
    >
      <img src={image.src} alt={image.alt} class="w-80 h-80 object-cover rounded-full" />
    </div>
  </div>
</section>
