---
import { leaderboard } from '@config/landing/leaderboard';

const medalBorder = ['border-yellow-400', 'border-slate-300', 'border-amber-600'];
const medalText = ['text-yellow-400', 'text-slate-400', 'text-amber-600'];
---

<section id="leaderboard" class="py-24 bg-surface-container-low">
  <div class="max-w-7xl mx-auto px-6 md:px-8">
    <div class="text-center mb-16">
      <h2 class="text-xs font-mono uppercase tracking-widest text-primary mb-2">
        {leaderboard.eyebrow}
      </h2>
      <h3 class="text-4xl md:text-5xl font-headline font-extrabold tracking-tight">
        {leaderboard.heading}
      </h3>
    </div>
    <div class="flex justify-center mb-12">
      <div class="inline-flex p-1 bg-surface-container-highest rounded-full" data-leaderboard-tabs>
        {
          leaderboard.tabs.map((tab, i) => (
            <button
              type="button"
              data-tab-index={i}
              class={
                i === 0
                  ? 'px-6 py-2 rounded-full bg-white shadow-sm font-headline font-bold text-sm'
                  : 'px-6 py-2 rounded-full text-on-surface-variant font-headline font-medium text-sm hover:text-on-surface'
              }
            >
              {tab}
            </button>
          ))
        }
      </div>
    </div>
    <div class="grid grid-cols-1 gap-4">
      {
        leaderboard.entries.map((entry, i) => {
          const isFirst = i === 0;
          return isFirst ? (
            <div class="glass-card p-8 rounded-xl flex flex-col md:flex-row items-center gap-8 border-2 border-yellow-400 shadow-[0_0_30px_rgba(250,204,21,0.15)] relative overflow-hidden">
              <div class="absolute top-0 right-0 p-4">
                <span class="material-symbols-outlined text-yellow-400 text-4xl" style="font-variation-settings: 'FILL' 1;">
                  workspace_premium
                </span>
              </div>
              <div class="text-6xl font-mono font-bold text-yellow-400 opacity-50">0{entry.rank}</div>
              <div class="w-20 h-20 rounded-full bg-surface-container-high border-2 border-white overflow-hidden">
                <img src={entry.avatar} alt={entry.avatarAlt} class="w-full h-full object-cover" />
              </div>
              <div class="flex-1 text-center md:text-left">
                <h4 class="text-2xl font-headline font-extrabold">{entry.name}</h4>
                <p class="text-primary font-mono text-sm">{entry.project}</p>
              </div>
              <div class="text-center md:text-right">
                <div class="text-xs font-mono uppercase text-on-surface-variant mb-1">Total Vibe Points</div>
                <div class="text-4xl font-headline font-extrabold text-primary">
                  {entry.vibePoints.toLocaleString()}
                </div>
              </div>
            </div>
          ) : (
            <div class={`glass-card p-6 rounded-xl flex flex-col md:flex-row items-center gap-6 border-l-8 ${medalBorder[i]}`}>
              <div class={`text-4xl font-mono font-bold ${medalText[i]}`}>0{entry.rank}</div>
              <div class="w-16 h-16 rounded-full bg-surface-container-high overflow-hidden">
                <img src={entry.avatar} alt={entry.avatarAlt} class="w-full h-full object-cover" />
              </div>
              <div class="flex-1 text-center md:text-left">
                <h4 class="text-xl font-headline font-bold">{entry.name}</h4>
                <p class="text-on-surface-variant font-mono text-xs">{entry.project}</p>
              </div>
              <div class="text-center md:text-right">
                <div class="text-[10px] font-mono uppercase text-on-surface-variant">Vibe Points</div>
                <div class="text-2xl font-headline font-extrabold">
                  {entry.vibePoints.toLocaleString()}
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<script>
  // Simple visual toggle for leaderboard tabs (data is the same for both tabs in this demo).
  const container = document.querySelector('[data-leaderboard-tabs]');
  if (container) {
    const buttons = container.querySelectorAll('button');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => {
          b.className =
            'px-6 py-2 rounded-full text-on-surface-variant font-headline font-medium text-sm hover:text-on-surface';
        });
        btn.className =
          'px-6 py-2 rounded-full bg-white shadow-sm font-headline font-bold text-sm';
      });
    });
  }
</script>
