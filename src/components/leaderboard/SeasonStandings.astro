---
import { seasonStandings } from '@config/leaderboard/standings';

const medalColor = ['#FFD700', '#C0C0C0', '#CD7F32'];
---

<section class="space-y-8">
  <div class="max-w-2xl">
    <h2 class="text-3xl md:text-4xl font-black tracking-tight mb-2">{seasonStandings.heading}</h2>
    <p class="text-on-surface-variant">{seasonStandings.description}</p>
  </div>
  <div class="space-y-3">
    {
      seasonStandings.entries.map((entry) => {
        const isTopThree = entry.rank < 4;
        const medal = medalColor[entry.rank - 1];
        if (isTopThree) {
          return (
            <div
              class="flex items-center gap-4 p-4 md:p-6 bg-surface-container-lowest rounded-xl border-l-8 shadow-sm glass-shimmer"
              style={`border-left-color: ${medal}`}
            >
              <div class="font-mono text-2xl md:text-3xl font-bold w-12" style={`color: ${medal}`}>
                0{entry.rank}
              </div>
              <div class="flex-1 flex items-center gap-4">
                <img src={entry.avatar} alt={entry.avatarAlt} class="w-12 h-12 rounded-full object-cover" />
                <div>
                  <div class="font-black text-base md:text-lg">{entry.name}</div>
                  <div class="text-xs font-mono uppercase text-on-surface-variant">{entry.team}</div>
                </div>
              </div>
              <div class="hidden md:block px-8 border-l border-outline-variant/10">
                <div class="text-[10px] font-mono text-on-surface-variant uppercase mb-1">Win Streak</div>
                <div class="flex gap-1">
                  {entry.winStreak?.map((filled) => (
                    <div class={`w-2 h-4 rounded-full ${filled ? 'bg-primary' : 'bg-outline-variant/20'}`} />
                  ))}
                </div>
              </div>
              <div class="text-right pl-4 md:pl-8 md:border-l border-outline-variant/10 min-w-[100px] md:min-w-[120px]">
                <div class="text-2xl md:text-3xl font-mono font-bold tracking-tighter">
                  {entry.vibePoints.toLocaleString()}
                </div>
                <div class="text-[10px] font-mono text-on-surface-variant uppercase">TOTAL VIBE POINTS</div>
              </div>
            </div>
          );
        }
        return (
          <div class="flex items-center gap-4 p-4 md:p-6 bg-surface-container-low/50 hover:bg-surface-container-low rounded-xl transition-all">
            <div class="font-mono text-2xl font-bold w-12 text-on-surface-variant/40">0{entry.rank}</div>
            <div class="flex-1 flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-slate-200 flex items-center justify-center font-bold text-slate-500">
                {entry.initials}
              </div>
              <div>
                <div class="font-bold">{entry.name}</div>
                <div class="text-[10px] font-mono uppercase text-on-surface-variant">{entry.team}</div>
              </div>
            </div>
            <div class="text-right pl-4 md:pl-8 min-w-[100px] md:min-w-[120px]">
              <div class="text-xl md:text-2xl font-mono font-bold tracking-tighter">
                {entry.vibePoints.toLocaleString()}
              </div>
              <div class="text-[10px] font-mono text-on-surface-variant uppercase">TOTAL VIBE POINTS</div>
            </div>
          </div>
        );
      })
    }
  </div>
</section>
