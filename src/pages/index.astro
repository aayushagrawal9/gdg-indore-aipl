---
import BaseLayout from '@components/layout/BaseLayout.astro';
import Hero from '@components/landing/Hero.astro';
import Ticker from '@components/landing/Ticker.astro';
import ScheduleCarousel from '@components/landing/ScheduleCarousel.astro';
import Leaderboard from '@components/landing/Leaderboard.astro';
import Playbook from '@components/landing/Playbook.astro';
import Partners from '@components/landing/Partners.astro';
import { site } from '@config/site';
---

<BaseLayout activeNav="Matches">
  <main>
    <Hero />
    <Ticker />
    <ScheduleCarousel />
    {site.features?.leaderboard && <Leaderboard />}
    <Playbook />
    <Partners />
  </main>
</BaseLayout>
